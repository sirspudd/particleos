[Transfer]
ProtectVersion=%A

[Source]
Type=url-file
Path=https://download.opensuse.org/repositories/system:/systemd/debian_testing_images/
MatchPattern=BananOS_@v_%a.efi

[Target]
Type=regular-file
Path=/EFI/Linux
PathRelativeTo=boot
MatchPattern=BananOS_@v_%a+@l-@d.efi \
  BananOS_@v_%a+@l.efi \
  BananOS_@v_%a.efi
Mode=0644
TriesLeft=3
TriesDone=0
InstancesMax=2
