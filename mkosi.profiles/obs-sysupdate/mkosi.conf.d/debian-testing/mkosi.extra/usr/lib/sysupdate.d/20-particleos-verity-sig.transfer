[Transfer]
ProtectVersion=%A

[Source]
Type=url-file
Path=https://download.opensuse.org/repositories/system:/systemd/debian_testing_images/
MatchPattern=BananOS_@v_%a.usr-%a-verity-sig.@u.raw.zst

[Target]
Type=partition
Path=auto
MatchPattern=BananOS_@v_verity_sig
MatchPartitionType=usr-verity-sig
PartitionFlags=0
ReadOnly=1
